{
	"compilerOptions": {
		"target": "ES2023",
		"module": "CommonJS",
		"lib": ["ES2023", "DOM"],
		"moduleResolution": "Node",
		"resolveJsonModule": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"strict": true,
		"skipLibCheck": true,
		"types": ["node", "@playwright/test"]
	},
	"include": ["tests", "playwright.config.ts"]
}
